#!/usr/bin/env php
<?php

declare(strict_types=1);

use Ineersa\CodingAgent\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Dotenv\Dotenv;

// Detect PHAR mode early. Box uses an internal PHAR alias (not Phar::running())
// so we check __FILE__ for the phar:// scheme instead.
// Inside a PHAR, __DIR__ points to phar://<alias>/bin which resolves correctly
// for require_once. The .env file is never bundled and must be skipped.
$isPhar = \str_starts_with(__FILE__, 'phar://');

require_once __DIR__.'/../vendor/autoload.php';

// ── PHAR runtime: extract filesystem-dependent resources ────────────────
// Inside a PHAR, certain Symfony/Doctrine components use realpath() or
// filesystem-based directory iteration that does not work with phar://
// stream paths (e.g. Doctrine Migrations finder). Extract such resources
// to a real filesystem path once per PHAR version.
//
// The extracted directory is reused across runs and cleaned on PHAR rebuild.
if ($isPhar) {
    $pharPath = (string) ($_SERVER['SCRIPT_FILENAME'] ?? __FILE__);
    $pharPrefix = 'phar://'.$pharPath;
    $extractDir = '/tmp/hatfield-phar-runtime';
    $extractStamp = $extractDir.'/.extracted';
    if (!is_dir($extractDir) || !is_file($extractStamp)) {
        @mkdir($extractDir.'/migrations', 0755, true);
        // Extract migration files using phar:// stream (not Phar object),
        // because opening the running PHAR with new Phar() triggers an
        // internal conflict with the already-loaded PHAR archive.
        $migrationFiles = scandir($pharPrefix.'/migrations');
        if (false !== $migrationFiles) {
            foreach ($migrationFiles as $mf) {
                if ($mf === '.' || $mf === '..') {
                    continue;
                }
                copy($pharPrefix.'/migrations/'.$mf, $extractDir.'/migrations/'.$mf);
            }
        }
        file_put_contents($extractStamp, date('c')."\n");
    }
    $_SERVER['HATFIELD_MIGRATIONS_DIR'] = $extractDir.'/migrations';
    $_ENV['HATFIELD_MIGRATIONS_DIR'] = $extractDir.'/migrations';
    putenv('HATFIELD_MIGRATIONS_DIR='.$extractDir.'/migrations');
} else {
    // Non-PHAR mode: point directly to the checkout migrations directory.
    $migrationsDir = \dirname(__DIR__).'/migrations';
    $_SERVER['HATFIELD_MIGRATIONS_DIR'] = $migrationsDir;
    $_ENV['HATFIELD_MIGRATIONS_DIR'] = $migrationsDir;
    putenv('HATFIELD_MIGRATIONS_DIR='.$migrationsDir);
}

// ── Early --cwd resolution ───────────────────────────────────────────────
// Resolve --cwd before Kernel/Application construction so getcwd() and
// Kernel::boot() see the correct working directory from startup. This ensures
// AppConfig uses the right CWD without requiring AgentCommand::chdir() after
// the container has already booted.
//
// Supports both forms: --cwd=/path and --cwd /path.
// Relative paths are resolved against the original shell CWD.
//
// After resolution, $_SERVER['argv'] is mutated so Symfony Console's
// ArgvInput and AgentCommand receive the absolute value. This prevents
// AgentCommand::__invoke() from re-validating a relative --cwd against
// the already-changed CWD and failing.
{
    $args = $_SERVER['argv'] ?? [];
    $cwdValue = null;
    $cwdIndex = null;
    foreach ($args as $i => $arg) {
        if (str_starts_with($arg, '--cwd=')) {
            $cwdValue = substr($arg, 6);
            $cwdIndex = $i;
            break;
        }
        if ($arg === '--cwd' && isset($args[$i + 1]) && !str_starts_with($args[$i + 1], '-')) {
            $cwdValue = $args[$i + 1];
            $cwdIndex = $i + 1;
            break;
        }
    }
    if (null !== $cwdValue && null !== $cwdIndex) {
        $resolved = str_starts_with($cwdValue, '/') ? $cwdValue : getcwd().'/'.$cwdValue;
        if (!is_dir($resolved)) {
            fwrite(STDERR, \sprintf("Error: Working directory does not exist: %s\n", $resolved));
            exit(1);
        }
        chdir($resolved);
        $_SERVER['HATFIELD_CWD'] = $resolved;
        $_ENV['HATFIELD_CWD'] = $resolved;
        putenv('HATFIELD_CWD='.$resolved);

        // Mutate argv so Symfony Console sees the resolved absolute path.
        // This prevents AgentCommand from receiving a relative --cwd value
        // that would fail is_dir() after chdir() already changed CWD.
        if (str_starts_with($_SERVER['argv'][$cwdIndex], '--cwd=')) {
            $_SERVER['argv'][$cwdIndex] = '--cwd='.$resolved;
        } elseif ($cwdIndex > 0 && $_SERVER['argv'][$cwdIndex - 1] === '--cwd') {
            $_SERVER['argv'][$cwdIndex] = $resolved;
        }
    }
    unset($args, $cwdValue, $cwdIndex, $resolved);
}

// In PHAR mode, .env is never bundled (no secrets in the archive).
// Tolerate its absence gracefully — env vars should be set by the
// parent process or system environment.
if (!$isPhar) {
    $envPath = dirname(__DIR__).'/.env';
    if (is_file($envPath)) {
        (new Dotenv())->bootEnv($envPath);
    }
}

$kernel = new Kernel($_SERVER['APP_ENV'] ?? 'prod', (bool) ($_SERVER['APP_DEBUG'] ?? false));
$application = new Application($kernel);
$application->run(new ArgvInput());
