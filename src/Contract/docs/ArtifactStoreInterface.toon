class: "Ineersa\\AgentCore\\Contract\\ArtifactStoreInterface"
type: interface
summary: "Defines the contract for persisting agent execution artifacts, such as logs or intermediate outputs, to a storage backend. It ensures consistent storage semantics across different implementations by standardizing the input parameters and return value for artifact registration."
