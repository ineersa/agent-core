class: "Ineersa\\AgentCore\\Contract\\PromptStateStoreInterface"
type: interface
summary: "Defines the contract for persisting and retrieving agent execution state keyed by run identifiers. It provides a minimal interface for storing, fetching, and removing structured state arrays associated with specific agent runs."
