spec: agent-core.ai-docs/v1
namespace: "Contract\\Tool"
fqcn: "Ineersa\\AgentCore\\Contract\\Tool"
description: "Tool execution contracts — platform invocation, model resolution, tool catalog discovery, tool executor, and idempotency key resolution."
files[5]{file,type,responsibility,docs}:
  PlatformInterface.php,interface,"LLM platform adapter — invoke a model with input/options, return raw response array.",docs/PlatformInterface.md
  ModelResolverInterface.php,interface,"Resolves which model to use — given default model, message bag, context, and options.",docs/ModelResolverInterface.md
  ToolCatalogProviderInterface.php,interface,Provides available tool definitions for a given context — the tool catalog.,docs/ToolCatalogProviderInterface.md
  ToolExecutorInterface.php,interface,"Executes a single tool call, returns a ToolResult.",docs/ToolExecutorInterface.md
  ToolIdempotencyKeyResolverInterface.php,interface,Optional stronger idempotency key contract — resolves a deterministic idempotency key from a ToolCall for result deduplication.,docs/ToolIdempotencyKeyResolverInterface.md
