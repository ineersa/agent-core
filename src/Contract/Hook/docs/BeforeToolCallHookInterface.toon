file: BeforeToolCallHookInterface.php
class: "Ineersa\\AgentCore\\Contract\\Hook\\BeforeToolCallHookInterface"
type: interface
summary: Defines the contract for intercepting tool invocations before execution begins. It allows external systems to inspect the tool call context and optionally abort the operation via a cancellation token. This interface serves as a pre-execution hook within the agent core workflow.
effects: none
dependencies: none
