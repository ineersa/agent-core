file: Platform.php
class: "Ineersa\\AgentCore\\Infrastructure\\SymfonyAi\\Platform"
type: readonly final class
summary: "The Platform class orchestrates the execution of AI agent runs within the Symfony infrastructure, bridging high-level agent inputs with the underlying provider invoker. It manages context resolution, message transformation, and hook application to prepare requests for external AI providers. The class ensures proper lifecycle management of runs and cancellation tokens while abstracting provider-specific details."
effects: "Writes run context to RunStoreInterface, dispatches cancellation signals via CancellationTokenInterface, and invokes external AI providers through SymfonyPlatformInvoker."
dependencies: "SymfonyPlatformInvoker, RunStoreInterface, ToolCatalogResolver, SymfonyMessageMapper, and external AI provider APIs."
