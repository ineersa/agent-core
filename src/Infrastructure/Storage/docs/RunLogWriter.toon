class: "Ineersa\\AgentCore\\Infrastructure\\Storage\\RunLogWriter"
type: readonly final class
summary: "The RunLogWriter class provides a mechanism for persisting RunEvent instances to the filesystem. It formats event data into structured files based on run identifiers and timestamps, ensuring durable storage of agent execution logs."
effects: writes event data to filesystem via FilesystemOperator
dependencies: "Ineersa\\AgentCore\\Infrastructure\\Storage\\RunEvent, League\\Flysystem\\FilesystemOperator"
