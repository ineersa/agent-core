class: "Ineersa\\AgentCore\\Infrastructure\\Storage\\InMemoryPromptStateStore"
type: final class
summary: "InMemoryPromptStateStore provides an ephemeral, in-memory storage mechanism for persisting prompt state associated with specific agent run IDs. It implements a simple key-value interface using an internal array to map run identifiers to their corresponding state arrays."
effects: none
dependencies: none
