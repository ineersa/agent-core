class: "Ineersa\\AgentCore\\Infrastructure\\Storage\\RunLogReader"
type: readonly final class
summary: "Reads run log files from the filesystem to reconstruct event sequences for a specific run. It parses JSON lines into domain events, providing a read-only view of historical run data."
