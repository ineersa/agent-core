spec: agent-core.ai-docs/v1
namespace: Http
fqcn: "Ineersa\\AgentCore\\Api\\Http"
updatedAt: 2026-04-21
files[2]{file,type,summary}:
  RunApiController.php,final class,"Exposes HTTP endpoints for starting runs, submitting commands, and reading run summaries, transcripts, and replay events with scoped access checks and payload validation."
  RunReadService.php,readonly final class,"This class provides HTTP-read access to run data and event transcripts by coordinating between run metadata stores and event storage. It retrieves summaries, paginated transcripts, and replayable event sequences while enforcing access control via the run access store."