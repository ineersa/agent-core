description: "Framework-agnostic core models: run state, commands, events, message envelopes, tool DTOs. Pure value objects with no infrastructure dependencies."
subNamespaces[5]{namespace,fqcn,path,description,index}:
  Run,"Ineersa\\AgentCore\\Domain\\Run",Run,"Run lifecycle value objects — RunId, RunHandle, RunState, RunStatus, StartRunInput.",Run/ai-index.toon
  Command,"Ineersa\\AgentCore\\Domain\\Command",Command,"Command value objects — CoreCommandKind constants, PendingCommand, RoutedCommand with core/extension/rejected discrimination.",Command/ai-index.toon
  Event,"Ineersa\\AgentCore\\Domain\\Event",Event,"Event sourcing models — RunEvent, Outbox pattern (Entry/Sink), BoundaryHookEvent/Name, CoreLifecycleEventType with validation, Lifecycle sub-namespace for typed events.",Event/ai-index.toon
  Message,"Ineersa\\AgentCore\\Domain\\Message",Message,"Message bus envelopes — AgentMessage, MessageBag, bus commands (StartRun, AdvanceRun, ApplyCommand, ExecuteLlmStep, ExecuteToolCall, CollectToolBatch), results (LlmStepResult, ToolCallResult), outbox projections.",Message/ai-index.toon
  Tool,"Ineersa\\AgentCore\\Domain\\Tool",Tool,"Tool execution value objects — ToolCall, ToolDefinition, ToolResult, execution modes, provider request/result, before/after hook contexts and results, model resolution.",Tool/ai-index.toon
