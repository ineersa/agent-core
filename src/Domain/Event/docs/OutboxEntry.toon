class: "Ineersa\\AgentCore\\Domain\\Event\\OutboxEntry"
type: readonly final class
summary: "Represents a durable record for an event pending delivery to an external sink. It encapsulates the event payload, target sink, and retry metadata to support reliable outbox pattern implementation."
