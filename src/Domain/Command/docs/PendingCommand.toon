class: "Ineersa\\AgentCore\\Domain\\Command\\PendingCommand"
type: readonly final class
summary: "PendingCommand represents a durable, immutable command record queued for asynchronous execution within the agent core domain. It encapsulates execution metadata including run identifiers, idempotency keys, and optional configuration payloads to ensure reliable processing."
