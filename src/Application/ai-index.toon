spec: agent-core.ai-docs/v1
namespace: Application
fqcn: "Ineersa\\AgentCore\\Application"
description: "Runtime coordination and flow: orchestrator, reducer, command router, effect dispatchers, tool execution, outbox projection, and event dispatching."
subNamespaces[3]{namespace,fqcn,path,description,index}:
  Orchestrator,"Ineersa\\AgentCore\\Application\\Orchestrator",Orchestrator,"Top-level orchestrators — AgentRunner (public API) dispatches to message bus; RunOrchestrator handles all bus messages with locking, idempotency, CQRS commit, and effect dispatch.",Orchestrator/ai-index.toon
  Handler,"Ineersa\\AgentCore\\Application\\Handler",Handler,"Handler infrastructure — command routing, registries, LLM/tool workers, outbox projectors, event dispatching, step dispatch, locking, idempotency, replay, tool batch collection.",Handler/ai-index.toon
  Reducer,"Ineersa\\AgentCore\\Application\\Reducer",Reducer,"Pure state reducer — transforms RunState given bus commands, produces effects for async execution.",Reducer/ai-index.toon
