type: final class
summary: "The RunReducer applies domain commands to a RunState to produce a new state or reduction result, enforcing the state transition logic for agent runs. It acts as the central reducer within the application layer, coordinating state mutations based on specific command types."
effects: none
dependencies: "RunState, AgentMessage"
