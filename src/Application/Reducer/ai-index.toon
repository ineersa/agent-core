spec: agent-core.ai-docs/v1
namespace: "Application\\Reducer"
fqcn: "Ineersa\\AgentCore\\Application\\Reducer"
description: "Pure state reducer — transforms RunState given bus commands (StartRun, AdvanceRun, ApplyCommand), returns new state + effects."
files[2]{file,type,responsibility,docs}:
  RunReducer.php,final class,"Pure reducer: maps (RunState, command) → ReduceResult(new state, effects). Handles StartRun (hydrate messages), AdvanceRun (bump turn, emit ExecuteLlmStep), ApplyCommand (cancel/steer/follow_up/human_response).",docs/RunReducer.md
  ReduceResult.php,readonly class,Reducer output — new RunState + list of effect commands to dispatch.,docs/ReduceResult.md
