file: AgentRunner.php
class: "Ineersa\\AgentCore\\Application\\Orchestrator\\AgentRunner"
type: final class
summary: "The AgentRunner class orchestrates the lifecycle of agent execution runs by translating high-level inputs into discrete, idempotent steps. It manages state transitions for starting, continuing, steering, and canceling runs while ensuring reliable message dispatch via a command bus."
effects: dispatches command messages to the MessageBusInterface
dependencies: MessageBusInterface
