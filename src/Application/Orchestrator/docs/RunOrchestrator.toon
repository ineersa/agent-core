spec: agent-core.file-index/v1
file: RunOrchestrator.php
class: "Ineersa\\AgentCore\\Application\\Orchestrator\\RunOrchestrator"
type: readonly final class
summary: "The RunOrchestrator coordinates the lifecycle of an agent run by processing commands and handling step results through a reducer pattern. It manages state transitions, tool execution policies, and message hydration while persisting events and commands to their respective stores."
