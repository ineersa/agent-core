class: "Ineersa\\AgentCore\\Application\\Handler\\JsonlOutboxProjectorWorker"
type: readonly final class
summary: The JsonlOutboxProjectorWorker consumes ProjectJsonlOutbox messages to persist event data into a JSONL outbox store. It coordinates the projection of domain events by writing to the outbox and logging execution details via a run log writer.
effects: writes to OutboxStoreInterface and RunLogWriter
dependencies: "OutboxStoreInterface, RunLogWriter"
