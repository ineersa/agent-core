class: "Ineersa\\AgentCore\\Application\\Handler\\ExecuteToolCallWorker"
type: readonly final class
summary: "This class acts as a message handler for the agent execution bus, processing tool call commands by delegating execution to a dedicated tool executor. It coordinates the invocation of external tools and manages the resulting state updates within the agent's runtime context."
effects: dispatches messages to 'agent.execution.bus' and writes state via RunStoreInterface
dependencies: "ToolExecutorInterface, MessageBusInterface, RunStoreInterface"
