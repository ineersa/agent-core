class: "Ineersa\\AgentCore\\Application\\Handler\\ToolBatchCollector"
type: final class
summary: "The ToolBatchCollector aggregates individual tool calls into batches based on run, turn, and step identifiers, enforcing a configurable maximum parallelism limit. It tracks expected batches and collects results to determine when a batch is complete and ready for dispatch."
