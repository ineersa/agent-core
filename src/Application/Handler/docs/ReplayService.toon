class: "Ineersa\\AgentCore\\Application\\Handler\\ReplayService"
type: readonly final class
summary: ReplayService reconstructs agent run state by replaying historical events from the event store and run logs. It verifies data integrity and rebuilds prompt state to ensure consistency across sequences.
effects: "reads from event store and run log reader, writes to prompt state store"
dependencies: "EventStoreInterface, RunLogReader, PromptStateStoreInterface"
