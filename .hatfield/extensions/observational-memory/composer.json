{
    "name": "ineersa/hatfield-ext-observational-memory",
    "description": "Observational memory extension for Hatfield (OM SQLite storage + async Observer pipeline)",
    "type": "hatfield-extension",
    "license": "MIT",
    "require": {
        "php": ">=8.5",
        "doctrine/dbal": "^4.3",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ineersa\\HatfieldExt\\ObservationalMemory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ineersa\\HatfieldExt\\ObservationalMemory\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
