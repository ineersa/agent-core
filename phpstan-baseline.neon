parameters:
	ignoreErrors:
		-
			message: '#^Method Ineersa\\CodingAgent\\CLI\\AgentCommand\:\:__invoke\(\) has parameter \$skills with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/CodingAgent/CLI/AgentCommand.php

		-
			message: '#^Method Ineersa\\CodingAgent\\CLI\\AgentCommand\:\:__invoke\(\) has parameter \$skillsPath with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: src/CodingAgent/CLI/AgentCommand.php

		-
			message: '#^Match arm comparison between Ineersa\\Tui\\Question\\QuestionKind\:\:Approval and Ineersa\\Tui\\Question\\QuestionKind\:\:Approval is always true\.$#'
			identifier: match.alwaysTrue
			count: 1
			path: src/Tui/Question/QuestionController.php
