includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-strict-rules/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon

parameters:
    level: 6
    treatPhpDocTypesAsCertain: false
    paths:
        - src/
        - castor.php
        - .castor/
        - .hatfield/extensions/
    scanFiles:
        - .castor.stub.php
        - .castor/helpers.php
    tmpDir: var/phpstan
    excludePaths:
        - .castor/vendor/*
        - var/*
        - vendor/*
        - .hatfield/extensions/vendor/*
        - .hatfield/extensions/task-workflow/tests/*
        - .hatfield/extensions/castor-llm-mode/tests/*
        - .hatfield/extensions/file-rewind/tests/*
    parallel:
        maximumNumberOfProcesses: 1
