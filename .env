###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=none
###< symfony/framework-bundle ###

# Default local/in-process messenger mode. The process controller overrides
# these to Doctrine SQLite DSNs for async run_control/llm/tool workers.
HATFIELD_RUN_CONTROL_TRANSPORT_DSN=sync://
HATFIELD_LLM_TRANSPORT_DSN=sync://
HATFIELD_TOOL_TRANSPORT_DSN=sync://
